services:
  web:
    build: ./app
    container_name: simple-chat-web
    restart: unless-stopped
    env_file:
      - ./app.env
    networks:
      - simple_chat_net

  nginx:
    image: nginx:stable
    container_name: simple-chat-nginx
    restart: unless-stopped
    depends_on:
      - web
    ports:
      - "8080:80"
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - simple_chat_net

networks:
  simple_chat_net:
